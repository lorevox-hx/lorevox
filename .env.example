# =========================
# Lorevox — environment config
# Copy this file to .env and edit for your machine.
# The launchers source .env automatically — edit here, not in the scripts.
# =========================

# =========================
# CORE PATHS
# =========================
# Canonical Lorevox data folder (DB, logs, memory archive, exports, etc.)
# Keep this OUTSIDE the repo tree so git never sees runtime data.
DATA_DIR=/mnt/c/lorevox_data
DB_NAME=lorevox.sqlite3

# Local model storage (outside repo)
# Windows path from WSL: /mnt/c/Llama-3.1-8B/hf/Meta-Llama-3.1-8B-Instruct
MODEL_PATH=/mnt/c/Llama-3.1-8B/hf/Meta-Llama-3.1-8B-Instruct

# HuggingFace cache (keep outside repo)
HF_HOME=/mnt/c/Llama-3.1-8B/hf_home
TRANSFORMERS_CACHE=/mnt/c/Llama-3.1-8B/hf_home

# Optional consolidated model root (used by some helper scripts)
MODEL_DIR=/mnt/c/Llama-3.1-8B

# Fallback model ID — only used if MODEL_PATH is empty/not set
# Requires HF token and network access; not needed for local installs.
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct

# =========================
# OFFLINE / HF SETTINGS
# =========================
# Keep HF from touching the network once the model is downloaded.
# Set to 0 only when you intentionally need to pull a new model or update.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# =========================
# SERVER
# =========================
HOST=127.0.0.1
PORT=8000
TTS_PORT=8001
LOG_LEVEL=INFO
APP_ENV=local

# =========================
# LLM / GENERATION
# =========================
MAX_NEW_TOKENS=7168
TEMPERATURE=0.3
LOAD_IN_4BIT=1
TORCH_DTYPE=bfloat16
ATTN_IMPL=sdpa

# =========================
# STT (faster-whisper — runs alongside LLM on port 8000)
# =========================
# large-v3 = best accuracy for names/proper nouns; ~3 GB VRAM on CUDA
# Alternatives: medium (1.5 GB), small (500 MB), base (150 MB)
STT_MODEL=large-v3
STT_GPU=1

# =========================
# TTS (Coqui VITS — runs on port 8001)
# =========================
# TTS_GPU=0 keeps VRAM free for LLM + STT on a single GPU.
# VITS on CPU is fast enough for sentence-streaming (~200-400ms/sentence).
TTS_MODEL=tts_models/en/vctk/vits
TTS_GPU=0
TTS_SPEAKER_LORI=p335
# Coqui model cache — keep outside repo (large model files)
TTS_HOME=/mnt/c/lorevox_data/tts_cache

# =========================
# LOREVOX FEATURE FLAGS — Original v9 (always-on legacy)
# =========================
LV_ENABLE_SAFETY=1
LV_ENABLE_AFFECT=1
LV_ENABLE_CAMERA=1
LV_ENABLE_TTS=1

# =========================
# LOREVOX FEATURE FLAGS — v10 (Hornelore-distilled features)
# =========================
# Truth Pipeline (WO-13). When 1, /api/facts/add returns 410 Gone and
# GET /api/profiles/{id} reads from family_truth_promoted.
LOREVOX_TRUTH_V2=1
LOREVOX_TRUTH_V2_PROFILE=1

# Photo system (WO-LORI-PHOTO-SHARED-01). Master switch for /api/photos/*.
# When 0, every photo route returns 404 except /health.
LOREVOX_PHOTO_ENABLED=1

# Photo intake Phase 2 (WO-LORI-PHOTO-INTAKE-01). EXIF auto-fill +
# reverse geocoder + Plus Code generator on upload. Independent flag
# inside the upload handler -- uploads still work without it but no
# auto-fill of date/location.
LOREVOX_PHOTO_INTAKE=1

# Document Archive (WO-MEDIA-ARCHIVE-01). PDFs / scanned docs /
# handwritten notes / genealogy outlines / letters / certificates.
# Master switch for /api/media-archive/*.
LOREVOX_MEDIA_ARCHIVE_ENABLED=1

# Memory Archive (WO-ARCHIVE-AUDIO-01). Per-session two-sided
# transcript + narrator-only audio capture + per-session zip export.
LOREVOX_ARCHIVE_ENABLED=1
# Optional caps (defaults shown). Over cap -> audio uploads return 413,
# transcript still flows. Uncomment to override.
# LOREVOX_ARCHIVE_MAX_MB_PER_PERSON=500
# LOREVOX_ARCHIVE_WARN_AT=0.8

# =========================
# LOREVOX EXTRACTOR LANE — flags (default OFF, experimental)
# =========================
# These control the extractor pipeline's still-iterating features.
# Keep at 0 for stable production. Lab development happens in the
# Hornelore repo where these flags are exercised on the master eval.
LOREVOX_NARRATIVE=0
LOREVOX_SPANTAG=0
LOREVOX_ATTRIB_BOUNDARY=0
LOREVOX_AGE_VALIDATOR=0
LOREVOX_PHASE_AWARE_QUESTIONS=0
LOREVOX_TWOPASS_EXTRACT=0
LOREVOX_PROMPTSHRINK=0
LOREVOX_SILENT_DEBUG=0
# Validators are SAFE guardrails; default ON.
LOREVOX_CLAIMS_VALIDATORS=1

# =========================
# LOREVOX PORT OVERRIDES (used by scripts/common.sh)
# =========================
# Defaults: API=8000, TTS=8001, UI=8080.
# LOREVOX_API_PORT=8000
# LOREVOX_TTS_PORT=8001
# LOREVOX_UI_PORT=8080

# =========================
# DEV / DEBUG (set to 0 in production)
# =========================
LV_DEV_MODE=0
LV_SHOW_DEBUG_PILLS=0

# =========================
# HUGGINGFACE AUTH (only needed to download gated models)
# =========================
# Uncomment and fill in only if you need to download a new gated model.
# Not needed once MODEL_PATH is set and HF_HUB_OFFLINE=1.
# HUGGINGFACE_HUB_TOKEN=hf_...
