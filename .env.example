# =========================
# Lorevox — environment config
# Copy this file to .env and edit for your machine.
# The launchers source .env automatically — edit here, not in the scripts.
# =========================

# =========================
# Paths / Data (LOCAL-FIRST)
# =========================
# Canonical Lorevox data folder (DB, logs, memory archive, exports, etc.)
DATA_DIR=/mnt/c/lorevox_data

# Optional DB overrides (relative to DATA_DIR)
DB_DIR=db
DB_NAME=lorevox.sqlite3

# UI static files path
UI_DIR=/mnt/c/Users/chris/lorevox/server/ui

# =========================
# Server
# =========================
HOST=0.0.0.0
PORT=8000
TTS_PORT=8001

# =========================
# GPU LLM (always local)
# =========================
# Set MODEL_PATH to your local model folder — the server NEVER touches the network
# Windows path from WSL: /mnt/c/Llama-3.1-8B/hf/Meta-Llama-3.1-8B-Instruct
MODEL_PATH=/mnt/c/Llama-3.1-8B/hf/Meta-Llama-3.1-8B-Instruct

# Fallback (only used if MODEL_PATH is empty/not set)
MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct

LOAD_IN_4BIT=1
TORCH_DTYPE=bfloat16
ATTN_IMPL=flash_attention_2
MAX_NEW_TOKENS=7168

# Keep HF from downloading elsewhere when MODEL_PATH is set
HF_HOME=/mnt/c/Llama-3.1-8B/hf_home
TRANSFORMERS_CACHE=/mnt/c/Llama-3.1-8B/hf_home

# =========================
# STT (faster-whisper — runs on LLM port 8000)
# =========================
# large-v3 = best accuracy for names/proper nouns; ~3 GB VRAM on CUDA
# Alternatives: medium (1.5 GB), small (500 MB), base (150 MB)
STT_MODEL=large-v3
STT_GPU=1

# =========================
# TTS (Coqui VITS — runs on port 8001)
# =========================
# TTS_GPU=0 keeps VRAM free for LLM + STT.
# VITS on CPU is fast enough for sentence-streaming (~200-400ms/sentence on modern CPU).
TTS_MODEL=tts_models/en/vctk/vits
TTS_GPU=0
TTS_SPEAKER_LORI=p335

# =========================
# HuggingFace (only needed to download gated models — not needed once MODEL_PATH is set)
# =========================
# HUGGINGFACE_HUB_TOKEN=hf_...
# HF_HUB_ENABLE_HF_TRANSFER=1
# HF_HUB_ENABLE_XET=1
